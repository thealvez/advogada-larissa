---
import type { PracticeArea } from '../../types/site';

interface Props {
  area: PracticeArea;
}

const { area } = Astro.props;
---

<article class="area-card">
  <h3>{area.title}</h3>
  <p>{area.summary}</p>
  <a href={`/areas/${area.slug}/`} aria-label={`Saiba mais sobre ${area.title}`}>
    Saiba mais
    <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .area-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  h3 {
    margin-block: 0;
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: 1.7rem;
    line-height: 1.08;
  }

  p {
    color: var(--color-text-muted);
  }

  a {
    margin-top: auto;
    color: var(--color-primary);
    font-weight: 800;
    text-decoration-color: var(--color-secondary);
    text-underline-offset: 0.3em;
  }
</style>

---
interface Props {
  professionalName: string;
}

const { professionalName } = Astro.props;
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${professionalName} - página inicial`}>
      <span class="brand-monogram" aria-hidden="true">AL</span>
      <span>
        <strong>{professionalName}</strong>
        <small>Atendimento jurídico online</small>
      </span>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation"
      data-menu-toggle
    >
      <span class="sr-only">Abrir menu de navegação</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav id="primary-navigation" aria-label="Navegação principal" data-menu>
      <a href="/#sobre">Sobre</a>
      <a href="/#areas">Áreas de atuação</a>
      <a href="/#atendimento">Como funciona</a>
      <a href="/#contato">Contato</a>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const toggle = header?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = header?.querySelector<HTMLElement>('[data-menu]');

  const setOpen = (isOpen: boolean) => {
    if (!header || !toggle) return;

    header.dataset.open = String(isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.querySelector('.sr-only')!.textContent = isOpen
      ? 'Fechar menu de navegação'
      : 'Abrir menu de navegação';
  };

  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 10;
    border-bottom: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.94);
  }

  .header-inner,
  .brand,
  nav {
    display: flex;
    align-items: center;
  }

  .header-inner {
    min-height: 5rem;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand {
    gap: var(--space-3);
    text-decoration: none;
  }

  .brand-monogram {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--color-primary-soft);
    border-radius: var(--radius-pill);
    background: var(--color-primary);
    color: var(--color-surface);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand small {
    color: var(--color-text-muted);
    font-size: 0.72rem;
  }

  nav {
    gap: var(--space-4);
  }

  nav a {
    color: var(--color-primary-soft);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    text-underline-offset: 0.24em;
  }

  nav a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .menu-toggle {
    display: none;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: transparent;
    cursor: pointer;
  }

  .menu-toggle span[aria-hidden] {
    display: block;
    width: 1.25rem;
    height: 2px;
    margin: 0.22rem auto;
    background: var(--color-primary);
  }

  .menu-toggle:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 4px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 42rem) {
    .menu-toggle {
      display: block;
    }

    nav {
      position: absolute;
      top: 100%;
      right: 1rem;
      left: 1rem;
      display: none;
      align-items: stretch;
      flex-direction: column;
      gap: 0;
      padding: var(--space-2);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-pill);
      background: var(--color-surface);
      box-shadow: var(--shadow-soft);
    }

    [data-open="true"] nav {
      display: flex;
    }

    nav a {
      padding: var(--space-3);
    }
  }
</style>
